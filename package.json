{
  "name": "docassemble-bankruptcyclinic-tests",
  "version": "1.0.0",
  "description": "Playwright tests for BankruptcyClinic docassemble interview",
  "scripts": {
    "test": "BASE_URL=http://localhost:8080 playwright test",
    "test:local": "BASE_URL=http://localhost:8080 playwright test",
    "test:remote": "BASE_URL=https://docassemble2.metatheria.solutions playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:ui": "playwright test --ui",
    "test:report": "playwright show-report",
    "test:smoke": "BASE_URL=http://localhost:8080 playwright test tests/smoke.spec.ts",
    "test:scenarios": "BASE_URL=http://localhost:8080 playwright test tests/scenario-*.spec.ts --workers=1",
    "test:pdfs": "BASE_URL=http://localhost:8080 playwright test tests/pdf-verification.spec.ts --workers=1",
    "test:maximalist": "BASE_URL=http://localhost:8080 playwright test tests/maximalist.spec.ts --workers=1",
    "test:quick": "BASE_URL=http://localhost:8080 playwright test tests/smoke.spec.ts tests/data-validation.spec.ts tests/edge-cases.spec.ts --workers=2",
    "test:watch-live": "LIVE_WATCH=1 playwright test --headed --workers=1",
    "test:live": "LIVE_WATCH=1 playwright test --headed --workers=1",
    "test:debug-step": "playwright test --debug --headed",
    "test:video-analysis": "playwright test --headed && npm run test:report"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@types/node": "^20.10.0",
    "pdf-lib": "^1.17.1",
    "playwright": "^1.55.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.7.3"
  },
  "keywords": [
    "playwright",
    "docassemble",
    "bankruptcy",
    "testing"
  ],
  "author": "",
  "license": "MIT"
}
